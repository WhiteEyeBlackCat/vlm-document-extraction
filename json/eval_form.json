{
  "schema_name": "ocr_eval_multi_document_template",
  "schema_version": "1.0",
  "description": "Template for OCR extraction, ground truth labeling, and error analysis across mixed trade-document PDFs in ./data.",
  "supported_document_types": [
    "invoice",
    "packing_list",
    "info_sheet",
    "unknown"
  ],
  "field_template": {
    "ocr_text": null,
    "normalized_value": null,
    "ground_truth": null,
    "is_correct": null,
    "confidence": null,
    "page": null,
    "bbox": null,
    "error_type": null,
    "notes": null
  },
  "table_cell_template": {
    "ocr_text": null,
    "normalized_value": null,
    "ground_truth": null,
    "is_correct": null,
    "confidence": null,
    "bbox": null,
    "error_type": null,
    "notes": null
