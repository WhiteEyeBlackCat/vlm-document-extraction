    "file_path": null,
    "file_name": null,
    "folder": null,
    "document_type": null,
    "document_type_confidence": null,
    "page_count": null,
    "language_hint": [
      "en",
      "zh"
    ],
    "status": {
      "ocr_done": false,
      "gt_labeled": false,
      "reviewed": false
    },
    "fields": {},
    "tables": [],
    "document_level_errors": [],
    "notes": null
