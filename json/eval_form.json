        "document_date": {
          "$ref": "field_template"
        },
        "issuer_name": {
          "$ref": "field_template"
        },
        "receiver_name": {
          "$ref": "field_template"
        },
        "total_amount": {
          "$ref": "field_template"
        },
        "currency": {
          "$ref": "field_template"
        },
        "remarks": {
